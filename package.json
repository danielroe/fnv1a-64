{
  "name": "fnv1a-64",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@11.13.0",
  "description": "Tiny, fast, dependency-free 64-bit FNV-1a string hash for Node and the browser",
  "license": "MIT",
  "repository": "danielroe/fnv1a-64",
  "keywords": [
    "fnv",
    "fnv1a",
    "fnv-1a",
    "hash",
    "64-bit",
    "non-cryptographic"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "vitest dev",
    "lint": "eslint . --fix",
    "prepare": "simple-git-hooks",
    "prepack": "pnpm build",
    "test": "pnpm test:unit && pnpm test:types",
    "test:unit": "vitest",
    "test:knip": "knip",
    "test:versions": "installed-check -d --no-workspaces",
    "bench": "node bench.mjs",
    "collisions": "node collisions.mjs",
    "test:types": "tsc --noEmit"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.1.0",
    "@sindresorhus/fnv1a": "^3.1.0",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "fnv-lite": "^1.2.0",
    "fnv-plus": "^1.3.1",
    "installed-check": "10.0.1",
    "knip": "6.26.0",
    "mitata": "^1.0.34",
    "murmurhash": "^2.0.1",
    "nano-staged": "1.0.2",
    "simple-git-hooks": "2.13.1",
    "tsdown": "0.22.7",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "xxhashjs": "^0.2.2"
  },
  "simple-git-hooks": {
    "pre-commit": "npx nano-staged"
  },
  "nano-staged": {
    "*.{js,ts,mjs,cjs,json,.*rc}": [
      "npx eslint --fix"
    ]
  }
}
